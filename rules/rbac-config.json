{
  "version": "1.0",
  "roles": ["super_admin", "admin", "accountant", "viewer"],
  "permissions": {
    "fiscal_periods": {
      "create": ["super_admin", "admin"],
      "update": ["super_admin", "admin"],
      "close": ["super_admin", "accountant"],
      "read": ["super_admin", "admin", "accountant", "viewer"]
    },
    "journal_entries": {
      "create": ["super_admin", "accountant"],
      "post": ["super_admin", "accountant"],
      "delete": ["super_admin"],
      "read": ["super_admin", "admin", "accountant", "viewer"]
    },
    "bank_reconciliation": {
      "link": ["super_admin", "accountant"],
      "export": ["super_admin", "admin", "accountant"],
      "read": ["super_admin", "admin", "accountant", "viewer"]
    },
    "reports": {
      "export_pdf": ["super_admin", "admin", "accountant"],
      "export_csv": ["super_admin", "admin", "accountant", "viewer"],
      "read": ["super_admin", "admin", "accountant", "viewer"]
    },
    "system": {
      "backup_restore": ["super_admin"],
      "manage_rules": ["super_admin"],
      "audit_view": ["super_admin", "admin"]
    }
  },
  "security": {
    "blockCrossTenantAccess": true,
    "logAllGuardChecks": true,
    "sessionCompanyIdSource": "auth_token"
  }
}